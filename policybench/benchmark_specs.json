                        "prompt": "annual Special Supplemental Nutrition Program for Women, Infants, and Children (WIC) benefit amount, using the benchmark's average package-value proxy",
                        "metric_type": "amount",
                        "role": "benefit",
                        "output_set": "supplementary",
                        "aggregation": "sum",
                        "net_income_sign": 1
                    },
                    {
                        "id": "person_wic_eligible",
                        "pe_variable": "is_wic_eligible",
                        "label": "Person-level WIC eligibility",
                        "prompt": "whether each person in the household is eligible for WIC (1 if yes, 0 if no)",
                        "metric_type": "binary",
                        "role": "coverage",
                        "output_set": "headline",
                        "aggregation": "person",
                        "net_income_sign": 1,
                        "impact_weight_variable": "wic",
                        "impact_weight_aggregation": "person"
                    },
