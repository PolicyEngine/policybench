{
    "default_spec": "v2",
    "specs": {
        "v2": {
            "description": "Rebuilt benchmark scope centered on non-overlapping household net-income components, with coverage flags weighted by PolicyEngine value proxies and intermediate tax bases moved to supplementary outputs.",
            "countries": {
                "us": [
                    {
                        "id": "federal_income_tax_before_refundable_credits",
                        "pe_variable": "income_tax_before_refundable_credits",
                        "label": "Federal tax before refundable credits",
                        "prompt": "federal individual income tax after nonrefundable credits and before refundable credits. This subtracts nonrefundable credits actually used, including CDCC and the nonrefundable portion of CTC or other credits when applicable; it does not subtract EITC or refundable portions of credits such as refundable CTC",
                        "metric_type": "amount",
                        "role": "tax",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": -1
                    },
                    {
                        "id": "federal_refundable_credits",
                        "pe_variable": "income_tax_refundable_credits",
                        "label": "Federal refundable credits",
                        "prompt": "total refundable federal income tax credits, including EITC and refundable portions of credits such as refundable CTC when applicable; exclude the ACA Premium Tax Credit",
                        "metric_type": "amount",
                        "role": "credit",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": 1
                    },
                    {
                        "id": "payroll_tax",
                        "pe_variable": "spm_unit_payroll_tax",
                        "label": "Payroll tax",
                        "prompt": "annual household employee-side payroll tax: employee Social Security tax, employee Medicare tax, Additional Medicare Tax, and mandatory employee state payroll taxes. Exclude employer payroll taxes, FUTA, employer unemployment-insurance taxes, and self-employment tax",
                        "metric_type": "amount",
                        "role": "tax",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": -1
                    },
                    {
                        "id": "self_employment_tax",
                        "pe_variable": "self_employment_tax",
                        "label": "Self-employment tax",
                        "prompt": "annual self-employment tax liability, excluding employee payroll taxes and Additional Medicare Tax",
                        "metric_type": "amount",
                        "role": "tax",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": -1
                    },
                    {
                        "id": "state_income_tax_before_refundable_credits",
                        "pe_variable": "state_income_tax_before_refundable_credits",
                        "label": "State tax before refundable credits",
                        "prompt": "state individual income tax after nonrefundable credits and before refundable credits, excluding local income and payroll taxes",
                        "metric_type": "amount",
                        "role": "tax",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": -1
                    },
                    {
                        "id": "state_refundable_credits",
                        "pe_variable": "state_refundable_credits",
                        "label": "State refundable credits",
                        "prompt": "total refundable state individual income tax credits",
                        "metric_type": "amount",
                        "role": "credit",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": 1
                    },
                    {
                        "id": "local_income_tax",
                        "pe_variable": "local_income_tax",
                        "label": "Local income tax",
                        "prompt": "annual local income, wage, and earnings tax liability in the separate local-income-tax output: NYC income tax, Philadelphia wage tax, Kansas City earnings tax, and St. Louis earnings tax where applicable",
                        "metric_type": "amount",
                        "role": "tax",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": -1
                    },
                    {
                        "id": "snap",
                        "pe_variable": "snap",
                        "label": "SNAP",
                        "prompt": "annual SNAP (food stamps) benefit amount",
                        "metric_type": "amount",
                        "role": "benefit",
                        "output_set": "headline",
                        "aggregation": "sum",
                        "net_income_sign": 1
                    },
                    {
                        "id": "ssi",
                        "pe_variable": "ssi",
